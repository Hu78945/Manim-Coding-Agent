GEMINI_API_KEY=
# Optional override, defaults to gemini-3-pro-preview
GEMINI_MODEL=

# Optional default for the CLI's provider prompt: "gemini" or "ollama"
AGENT_PROVIDER=

# Ollama (for open-source models). Requires `ollama serve` running locally
# with at least one model pulled. No API key needed for local use.
OLLAMA_HOST=
OLLAMA_MODEL=
# Only needed for Ollama's cloud API (https://ollama.com)
OLLAMA_API_KEY=
